{
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,

  "semi": true,
  "singleQuote": false,
  "quoteProps": "as-needed",

  "trailingComma": "es5",
  "bracketSpacing": false,
  "bracketSameLine": false,

  "arrowParens": "avoid",
  "endOfLine": "lf",

  "jsxSingleQuote": false,
  "jsxBracketSameLine": false,

  "proseWrap": "preserve"
}
